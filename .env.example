# MSC environment template
# Local (Cursor):  copy this file to .env.local and replace every placeholder.
# Live (hPanel):   set the same keys in Node.js app environment (not in Git).

# --- Payload CMS ---
PAYLOAD_SECRET=your-super-secret-key-change-this
DATABASE_URL=file:./payload.sqlite

# --- Public URLs (local dev) ---
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
# Production only (hPanel Node env — do NOT set in .env.local for normal dev):
# PAYLOAD_PUBLIC_SERVER_URL=https://mystudiochannel.com

# --- Booking ---
NEXT_PUBLIC_MSC_BOOKING_URL=payload

# --- Email (Resend) ---
RESEND_API_KEY=1234567890_example_replace_me

# --- Host / shared hosting ---
PAYLOAD_DISABLE_SHARP=true

# --- GitHub (repo backups, MCP: npm run test:github-api / sync:mcp-env) ---
GITHUB_PERSONAL_ACCESS_TOKEN=1234567890_example_replace_me

# --- Tavily (web search MCP — npm run sync:mcp-env) ---
TAVILY_API_KEY=1234567890_example_replace_me

# --- WordPress MCP (project .cursor/mcp.json — npm run sync:mcp-env) ---
WORDPRESS_SITE_URL=http://mscclean.local
WORDPRESS_USERNAME=admin
WORDPRESS_APP_PASSWORD=your-wp-application-password

# --- FTPS deploy target (Hostinger Node.js app root) ---
# FTP_HOST=ftp.mystudiochannel.com
# FTP_USERNAME=your-ftp-user
# FTP_PASSWORD=your-ftp-password
# FTP_PORT=21
# FTP_REMOTE_PATH=/nodejs

# --- Temporary live debug (remove after fixing projects-home API) ---
# ENABLE_DEV_LAB=true
# MSC_DEBUG_SECRET=generate-a-long-random-string
# Then: GET /api/dev/debug-projects-home?token=<MSC_DEBUG_SECRET>
# Log file on server: debug-projects-home.log (app root)

# --- Optional (uncomment if needed) ---
# DATABASE_AUTH_TOKEN=
# MSC_CANONICAL_SITE_ORIGIN=https://mystudiochannel.com
# PAYLOAD_CSRF_EXTRA_ORIGINS=
# PAYLOAD_DB_PUSH=true
# NEXT_PUBLIC_SCHEDULE_CALL_URL=https://example.com/schedule

# --- google-api-proxy module (append to .env.example) ---
MSC_LITELLM_PORT=4000
MSC_LITELLM_START_NGROK=0
# MSC_NGROK_BIN=google-api/ngrok.exe
# NGROK_AUTHTOKEN=your_ngrok_authtoken
GOOGLE_APPLICATION_CREDENTIALS=config/gcp-service-account.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
MSC_LITELLM_MASTER_KEY=your_litellm_master_key_local_only
# MSC_LITELLM_CONFIG=config/litellm_config.yaml


# --- backup-system module (append to .env.example) ---
# MSC_BACKUP_ROOT=G:\Cursor_Project_BackUpz\MyStudioChannel

