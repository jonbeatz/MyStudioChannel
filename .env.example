# MSC unified environment template
# Local (Cursor): copy this file to .env.local and set local-safe values.
# Live (hPanel): set production values in Node.js -> Environment Variables.
# This single file replaces .env.production.template.

# --- Payload CMS ---
PAYLOAD_SECRET=your-super-secret-key-change-this
DATABASE_URL=file:./payload.sqlite

# --- Public URLs ---
# Local default:
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
# Production (hPanel):
# NEXT_PUBLIC_SERVER_URL=https://mystudiochannel.com
PAYLOAD_PUBLIC_SERVER_URL=https://mystudiochannel.com

# --- Booking ---
NEXT_PUBLIC_MSC_BOOKING_URL=payload

# --- Email (Resend) ---
RESEND_API_KEY=1234567890_example_replace_me

# --- Host / shared hosting ---
PAYLOAD_DISABLE_SHARP=true
NODE_ENV=production
# Hostinger usually provides PORT; keep 3000 as safe fallback.
PORT=3000

# --- GitHub (repo backups, MCP: npm run test:github-api / sync:mcp-env) ---
GITHUB_PERSONAL_ACCESS_TOKEN=1234567890_example_replace_me

# --- Tavily (web search MCP — npm run sync:mcp-env) ---
TAVILY_API_KEY=1234567890_example_replace_me

# --- WordPress MCP (project .cursor/mcp.json — npm run sync:mcp-env) ---
WORDPRESS_SITE_URL=http://mscclean.local
WORDPRESS_USERNAME=admin
WORDPRESS_APP_PASSWORD=your-wp-application-password

# --- Hostinger MCP (global ~/.cursor/mcp.json — npm run msc:sync:mcp-env) ---
# From hPanel → API / Hostinger MCP connector
HOSTINGER_API_TOKEN=1234567890_example_replace_me

# --- Project MCP (project .cursor/mcp.json — npm run msc:sync:mcp-env) ---
# 21ST_DEV_MAGIC_API_KEY=your-21st-dev-key
# BROWSERBASE_API_KEY=your-browserbase-key
# BROWSERBASE_PROJECT_ID=your-browserbase-project-id
# GEMINI_API_KEY=your-gemini-key

# --- FTPS deploy target (Hostinger Node.js app root) ---
# FTP_HOST=ftp.mystudiochannel.com
# FTP_USERNAME=your-ftp-user
# FTP_PASSWORD=your-ftp-password
# FTP_PORT=21
# FTP_REMOTE_PATH=/nodejs

# --- Temporary live debug (remove after fixing projects-home API) ---
# ENABLE_DEV_LAB=true
# MSC_DEBUG_SECRET=generate-a-long-random-string
# Then: GET /api/dev/debug-projects-home?token=<MSC_DEBUG_SECRET>
# Log file on server: debug-projects-home.log (app root)

# --- Optional (uncomment if needed) ---
# DATABASE_AUTH_TOKEN=
# MSC_CANONICAL_SITE_ORIGIN=https://mystudiochannel.com
# PAYLOAD_CSRF_EXTRA_ORIGINS=
# PAYLOAD_DB_PUSH=true
# NEXT_PUBLIC_SCHEDULE_CALL_URL=https://example.com/schedule

# --- google-api-proxy module (append to .env.example) ---
MSC_LITELLM_PORT=4000
MSC_LITELLM_START_NGROK=0
# MSC_NGROK_BIN=google-api/ngrok.exe
# NGROK_AUTHTOKEN=your_ngrok_authtoken
GOOGLE_APPLICATION_CREDENTIALS=config/gcp-service-account.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
MSC_LITELLM_MASTER_KEY=your_litellm_master_key_local_only
# MSC_LITELLM_CONFIG=config/litellm_config.yaml
# Cursor Models: set Override OpenAI Base URL + API key in Cursor Settings (printed by npm run msc:litellm:test:ngrok)

# --- backup-system module (append to .env.example) ---
# MSC_BACKUP_ROOT=G:\Cursor_Project_BackUpz\MyStudioChannel

# --- Sentry (error monitoring — npm run build uploads source maps when token is set) ---
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
# SENTRY_AUTH_TOKEN=your_sentry_auth_token_for_sourcemap_uploads



# --- Hostinger deploy (hostinger-setup module — fill in .env.local) ---
# FTPS staging path is usually public_html/nodejs — live app root differs (see HOSTINGER-MODULE.md)
FTP_HOST=ftp.example.com
FTP_USERNAME=your-ftp-user
FTP_PASSWORD=your-ftp-password
FTP_PORT=21
FTP_REMOTE_PATH=/nodejs

# SSH (Hostinger hPanel → Advanced → SSH Access)
HOSTINGER_SSH_HOST=your-server-ip
HOSTINGER_SSH_PORT=65002
HOSTINGER_SSH_USER=your-ssh-user
HOSTINGER_SSH_PASSWORD=your-ssh-password
HOSTINGER_APP_ROOT=/home/uXXXX/domains/example.com/nodejs

# Hostinger MCP (global ~/.cursor/mcp.json — npm run msc:sync:mcp-env)
HOSTINGER_API_TOKEN=your-hostinger-api-token



# Hugging Face Access Token for Serverless Image Generation (FLUX.1)
HF_TOKEN=hf_your_access_token_here

