# My Studio Channel - Hostinger Production Environment
# Copy these keys into Hostinger hPanel -> Advanced -> Environment Variables
# Do NOT commit real values to Git.

# --- Core Payload CMS ---
# Generate a long, random string for production
PAYLOAD_SECRET=

# Use relative path for SQLite or absolute path from Hostinger root
DATABASE_URL=file:./payload.sqlite

# --- Public URLs ---
# Set to your official domain (e.g., https://mystudiochannel.com)
NEXT_PUBLIC_SERVER_URL=
# Recommended for production runtime
PAYLOAD_PUBLIC_SERVER_URL=

# --- Booking & Email ---
# Use 'payload' to store bookings in the local SQLite DB
NEXT_PUBLIC_MSC_BOOKING_URL=payload
# Transactional email API key
RESEND_API_KEY=

# --- Performance & Compatibility ---
# Recommended for shared hosting (Hostinger) to avoid native sharp issues
PAYLOAD_DISABLE_SHARP=true
# Set to 'production' for optimized build behavior
NODE_ENV=production
# Hostinger will provide this dynamically, but 3000 is a safe fallback
PORT=3000
