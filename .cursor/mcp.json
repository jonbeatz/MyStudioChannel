{
  "mcpServers": {
    "local-wp": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@verygoodplugins/mcp-local-wp@latest"
      ],
      "_comment": "Local by Flywheel / Local WP site discovery for mscclean.local"
    },
    "mcp-wordpress": {
      "command": "cmd",
      "args": [
        "/c",
        "node",
        "C:\\Users\\JONBEATZ\\AppData\\Roaming\\npm\\node_modules\\mcp-wordpress\\dist\\index.js"
      ],
      "env": {
        "WORDPRESS_SITE_URL": "REPLACE_WITH_WP_SITE_URL",
        "WORDPRESS_USERNAME": "REPLACE_WITH_WP_USERNAME",
        "WORDPRESS_APP_PASSWORD": "REPLACE_WITH_WP_APP_PASSWORD"
      },
      "_comment": "WordPress REST MCP — credentials synced from .env.local via npm run msc:sync:mcp-env"
    },
    "browserbase": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@browserbasehq/mcp"
      ],
      "env": {
        "BROWSERBASE_API_KEY": "bb_live_iwuF69yEwYCUx7l7cALivMpIAnU",
        "BROWSERBASE_PROJECT_ID": "713e6b70-0afc-4fea-a824-75fc3e4c9f8e"
      },
      "_comment": "Cloud browser automation with Browserbase and Stagehand."
    },
    "21st-dev-magic": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@21st-dev/magic@latest"
      ],
      "env": {
        "API_KEY": "bd5cc7d159e95e09b7a4ad5329d59e5f03d47182a0665aa62eccaf5f393f712e"
      },
      "_comment": "Allows building beautiful frontend components directly into the codebase with 21st.dev Magic MCP."
    },
    "markdownify": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "mcp-markdownify-server"
      ],
      "_comment": "Converts web content, PDFs, images (OCR), and document files directly to Markdown."
    }
  }
}