
# --- Hostinger deploy (hostinger-setup module — fill in .env.local) ---
# FTPS staging path is usually public_html/nodejs — live app root differs (see HOSTINGER-MODULE.md)
FTP_HOST=ftp.example.com
FTP_USERNAME=your-ftp-user
FTP_PASSWORD=your-ftp-password
FTP_PORT=21
FTP_REMOTE_PATH=/nodejs

# SSH (Hostinger hPanel → Advanced → SSH Access)
HOSTINGER_SSH_HOST=your-server-ip
HOSTINGER_SSH_PORT=65002
HOSTINGER_SSH_USER=your-ssh-user
HOSTINGER_SSH_PASSWORD=your-ssh-password
HOSTINGER_APP_ROOT=/home/uXXXX/domains/example.com/nodejs

# Hostinger MCP (global ~/.cursor/mcp.json — npm run msc:sync:mcp-env)
HOSTINGER_API_TOKEN=your-hostinger-api-token
