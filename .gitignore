# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules

# next.js
/.next/
/out/

# production
/build

# debug
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (track .env.example; never commit .env.local)
.env*
!.env.example
# Hostinger import bundle (secrets — PC only)
.cursor/MSC-Hostinger/

# Payload / SQLite (ignore WAL sidecars)
# Do NOT ignore payload.sqlite for the initial Hostinger deploy seed.
# After first deploy, you may add it back to prevent overwriting prod data.
# payload.sqlite
payload.sqlite-*
payload.sqlite.temp
.payload

# vercel
.vercel

# Cursor stop-hook machine-local HEAD pointer (not source of truth)
.cursor/.last-stop-hook-commit

# MCP sync script backups (local; regenerate on sync)
.cursor/*.sync-bak

# Personal secrets vault (never commit — local only)
.cursor/docs/Personal-Secrets-Vault.md
.cursor/docs/Personal-Secrets-Vault-Credentials.md

# Local GitHub repo backups (large; regenerate with npm run backup:github-repos)
.cursor/GitHub-Repo-BackUps/

# Python
__pycache__/
*.py[cod]

# local editor deploy secrets
.vscode/sftp.json
.vscode/cpanel-bookmarks.txt

# local deploy artifacts / logs (keep out of Git; large binaries)
parity-ftp-report.md
stderr.log
debug-projects-home.log
.pushitupzips/
# Deployment zips (timestamped archives for Hostinger MCP / manual upload)
zips/
# Deployment archives (created by PushItUP scripts)
*.zip
!*.example.zip
!*.template.zip

# google-api-proxy (never commit service account JSON or ngrok token files)
config/gcp-service-account.json
google-api/gcp_key.json
google-api/ngrok.exe
**/Ngrok-API.md
**/gcp-service-account.json

# typescript
*.tsbuildinfo
next-env.d.ts